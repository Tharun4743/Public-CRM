# SMTP Configuration for Real Emails
# Leave these blank to use the "Console Log" mode for development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI Configuration (OpenRouter/OpenLLM / Ollama)
AI_API_KEY=
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
OLLAMA_URL=http://localhost:11434

# MongoDB Configuration
MONGODB_URI=mongodb+srv://...

# Security & Secrets
JWT_SECRET=your_jwt_secret_here
ADMIN_DB_KEY=pscrm-admin-2024
ADMIN_EMAIL=admin@ps-crm.gov
